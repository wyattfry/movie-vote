<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Movie Night Voting</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <link href="/css/style.css" rel="stylesheet">
</head>

<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary">
        <div class="container">
            <a class="navbar-brand" href="/">
                <i class="fas fa-film me-2"></i>Movie Night Voting
            </a>
        </div>
    </nav>

    <div class="container mt-4">
        <div class="row">
            <div class="col-lg-4">
                <div class="card shadow-sm">
                    <div class="card-header bg-success text-white">
                        <h5 class="card-title mb-0">
                            <i class="fas fa-plus-circle me-2"></i>Suggest a Movie
                        </h5>
                    </div>
                    <div class="card-body">
                        <form id="suggestForm">
                            <div class="mb-3">
                                <label for="title" class="form-label">Movie Title *</label>
                                <input type="text" class="form-control" id="title" name="title" required>
                            </div>
                            <div class="mb-3">
                                <label for="description" class="form-label">Optional note why you think it should be
                                    included</label>
                                <textarea class="form-control" id="description" name="description" rows="3"
                                    placeholder="Why do you think this movie would be great for movie night?"></textarea>
                            </div>
                            <div class="mb-3">
                                <label for="suggested_by" class="form-label">Your Name *</label>
                                <input type="text" class="form-control" id="suggested_by" name="suggested_by" required>
                            </div>
                            <button type="submit" class="btn btn-success w-100">
                                <i class="fas fa-paper-plane me-2"></i>Suggest Movie
                            </button>
                        </form>
                    </div>
                </div>

                <div class="card shadow-sm mt-4">
                    <div class="card-header bg-info text-white">
                        <h6 class="card-title mb-0">
                            <i class="fas fa-info-circle me-2"></i>How it works
                        </h6>
                    </div>
                    <div class="card-body">
                        <ul class="list-unstyled mb-0">
                            <li class="mb-2"><i class="fas fa-check text-success me-2"></i>Suggest movies for movie
                                night</li>
                            <li class="mb-2"><i class="fas fa-check text-success me-2"></i>Vote for your favorites</li>
                            <li class="mb-2"><i class="fas fa-check text-success me-2"></i>One vote per movie per person
                            </li>
                            <li class="mb-0"><i class="fas fa-check text-success me-2"></i>Can't vote for your own
                                suggestions</li>
                        </ul>
                    </div>
                </div>
            </div>

            <div class="col-lg-8">
                <div class="card shadow-sm">
                    <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                        <h5 class="card-title mb-0">
                            <i class="fas fa-trophy me-2"></i>Movie Suggestions
                        </h5>
                        <span class="badge bg-light text-dark" id="movieCount">
                            <%= movies.length %> movies
                        </span>
                    </div>
                    <div class="card-body">
                        <div id="moviesList">
                            <% if (movies.length===0) { %>
                                <div class="text-center py-5 text-muted">
                                    <i class="fas fa-film fa-3x mb-3"></i>
                                    <h6>No movie suggestions yet!</h6>
                                    <p>Be the first to suggest a movie for movie night.</p>
                                </div>
                                <% } else { %>
                                    <div class="row">
                                        <% movies.forEach(movie=> { %>
                                            <div class="col-md-6 col-lg-4 mb-4" data-movie-id="<%= movie.id %>">
                                                <div class="card movie-card h-100">
                                                    <% const posterSrc=movie.local_poster_path || movie.poster_url; %>
                                                        <% if (posterSrc) { %>
                                                            <img src="<%= posterSrc %>"
                                                                class="card-img-top movie-poster"
                                                                alt="<%= movie.title %>">
                                                            <% } else { %>
                                                                <div class="movie-placeholder">
                                                                    <i class="fas fa-film fa-3x text-muted"></i>
                                                                </div>
                                                                <% } %>
                                                                    <div class="card-body d-flex flex-column">
                                                                        <div class="mb-2">
                                                                            <h6 class="card-title mb-1">
                                                                                <%= movie.title %>
                                                                            </h6>
                                                                            <div class="movie-meta">
                                                                                <% if (movie.year) { %>
                                                                                    <span
                                                                                        class="badge bg-secondary me-1">
                                                                                        <%= movie.year %>
                                                                                    </span>
                                                                                    <% } %>
                                                                                        <% if (movie.rating) { %>
                                                                                            <span
                                                                                                class="badge bg-warning">
                                                                                                <i
                                                                                                    class="fas fa-star"></i>
                                                                                                <%= movie.rating.toFixed(1)
                                                                                                    %>
                                                                                            </span>
                                                                                            <% } %>
                                                                            </div>
                                                                        </div>
                                                                        <% if (movie.description) { %>
                                                                            <p
                                                                                class="card-text flex-grow-1 movie-description">
                                                                                <%= movie.description %>
                                                                            </p>
                                                                            <% } %>
                                                                                <div class="mt-auto">
                                                                                    <div
                                                                                        class="d-flex justify-content-between align-items-center">
                                                                                        <small class="text-muted">by <%=
                                                                                                movie.suggested_by %>
                                                                                        </small>
                                                                                        <div class="vote-section">
                                                                                            <% if (movie.user_suggested)
                                                                                                { %>
                                                                                                <button
                                                                                                    class="btn btn-outline-secondary btn-sm me-1"
                                                                                                    disabled>
                                                                                                    <i
                                                                                                        class="far fa-heart"></i>
                                                                                                    <%= movie.votes %>
                                                                                                </button>
                                                                                                <button
                                                                                                    class="btn btn-danger btn-sm delete-movie-btn"
                                                                                                    data-movie-id="<%= movie.id %>"
                                                                                                    title="Delete your suggestion">
                                                                                                    <i
                                                                                                        class="fas fa-trash"></i>
                                                                                                </button>
                                                                                                <% } else if
                                                                                                    (movie.user_voted) {
                                                                                                    %>
                                                                                                    <button
                                                                                                        class="btn btn-outline-danger btn-sm remove-vote-btn"
                                                                                                        data-movie-id="<%= movie.id %>">
                                                                                                        <i
                                                                                                            class="fas fa-heart"></i>
                                                                                                        <%= movie.votes
                                                                                                            %>
                                                                                                    </button>
                                                                                                    <% } else { %>
                                                                                                        <button
                                                                                                            class="btn btn-outline-primary btn-sm vote-btn"
                                                                                                            data-movie-id="<%= movie.id %>">
                                                                                                            <i
                                                                                                                class="far fa-heart"></i>
                                                                                                            <%= movie.votes
                                                                                                                %>
                                                                                                        </button>
                                                                                                        <% } %>
                                                                                        </div>
                                                                                    </div>
                                                                                </div>
                                                                    </div>
                                                </div>
                                            </div>
                                            <% }) %>
                                    </div>
                                    <% } %>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Toast for notifications -->
    <div class="toast-container position-fixed bottom-0 end-0 p-3">
        <div id="notificationToast" class="toast" role="alert" aria-live="assertive" aria-atomic="true">
            <div class="toast-header">
                <i class="fas fa-film text-primary me-2"></i>
                <strong class="me-auto">Movie Voting</strong>
                <button type="button" class="btn-close" data-bs-dismiss="toast" aria-label="Close"></button>
            </div>
            <div class="toast-body" id="toastMessage">
                <!-- Toast message will be inserted here -->
            </div>
        </div>
    </div>

    <!-- Loading overlay -->
    <div id="loadingOverlay" class="loading-overlay">
        <div class="loading-spinner">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
            <div class="mt-2">Loading movie data...</div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/app.js"></script>
</body>

</html>